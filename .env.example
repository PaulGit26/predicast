# ─── PREDICAST — Environment Variables ────────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env to git.

# ── Application ───────────────────────────────────────────────────────────────
ENV=production                          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO
LOG_FORMAT=json

# ── Backend API ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=https://app.predicast.com,https://predicast.com

# ── Auth0 (RS256) ─────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://api.predicast.com
# Client credentials for M2M (pipeline triggers, etc.)
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# ── JWT (dev only — leave empty in prod to force Auth0) ───────────────────────
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRATION_HOURS=24

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://predicast:predicast@postgres:5432/predicast
POSTGRES_USER=predicast
POSTGRES_PASSWORD=predicast
POSTGRES_DB=predicast

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_MODELS=predicast-models
S3_BUCKET_DATA=predicast-data

# ── Data paths ────────────────────────────────────────────────────────────────
DATA_DIR=/data/01_Datos
DATA_ROOT=/data

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Prefect ───────────────────────────────────────────────────────────────────
PREFECT_API_URL=http://prefect:4200/api

# ── Pipeline service ──────────────────────────────────────────────────────────
PIPELINE_URL=http://pipeline:5001

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXTAUTH_URL=https://app.predicast.com
NEXTAUTH_SECRET=change-me-in-production
AUTH0_NEXTAUTH_CLIENT_ID=
AUTH0_NEXTAUTH_CLIENT_SECRET=
NEXT_PUBLIC_API_URL=https://api.predicast.com
BACKEND_URL=http://backend:8000
