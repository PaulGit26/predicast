# ============================================
# ENVIRONMENT VARIABLES - COPY TO .env
# ============================================

# ---- SISTEMA ----
ENVIRONMENT=development
DEBUG=True
TENANT_ID=empresa_a
SECRET_KEY=tu-secret-key-cambiar-en-produccion

# ---- FLASK API ----
FLASK_APP=src/api/main.py
FLASK_ENV=development
API_PORT=5000
API_HOST=0.0.0.0

# ---- DATABASE ----
# Development: SQLite
DATABASE_URL=sqlite:///predicast.db

# Production: PostgreSQL (descomenta para usar)
# DATABASE_URL=postgresql://user:password@localhost:5432/predicast

# ---- JWT AUTH ----
JWT_SECRET=tu-jwt-secret-cambiar-en-produccion
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ---- STREAMLIT ----
STREAMLIT_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost

# ---- ML MODELS PATH ----
# Usar rutas relativas o absolutas
# RELATIVA (desde 07_Sistema_Produccion): ../../03_Modelos/...
# ABSOLUTA: d:\Desktop\Predicast\03_Modelos\...
MODEL_PATH=../../../03_Modelos/xgboost_model_V2_V2_Realista.joblib
METADATA_PATH=../../../03_Modelos/xgboost_metadata_V2_V2_Realista.json

# ---- DATA ----
DATA_PATH=../../../01_Datos

# ---- LOGGING ----
LOG_LEVEL=INFO
