# ===== ENVIRONMENT =====
# development, staging, production
ENV=development
DEBUG=True

# ===== API (FastAPI + Uvicorn) =====
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://localhost:8000

# ===== DATABASE (PostgreSQL) =====
# Dev/local: postgresql://user:password@localhost/dbname
DATABASE_URL=postgresql://predicast_user:predicast_password@localhost:5432/predicast_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===== CACHE (Redis) =====
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ===== AUTHENTICATION (JWT) =====
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production-12345678901234567890
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ===== AWS S3 =====
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-1
S3_BUCKET_MODELS=predicast-models-dev
S3_BUCKET_DATA=predicast-data-dev

# ===== ML / MLFLOW =====
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_REGISTRY=mlflow
MODEL_VERSION_PRODUCTION=production

# ===== OBSERVABILITY =====
LOG_LEVEL=DEBUG
LOG_FORMAT=json
SENTRY_DSN=
ENABLE_TRACING=False

# ===== PREFECT (Orchestration) =====
PREFECT_API_URL=http://localhost:4200/api

# ===== RAY (Distributed Computing) =====
RAY_CLUSTER_HEAD=127.0.0.1
RAY_CLUSTER_PORT=6379
